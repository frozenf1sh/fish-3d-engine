{
  "name": "fish-engine",
  "version": "0.1.0",
  "description": "A modern C++ 3D graphics engine",
  "dependencies": [
    {
      "name": "glfw3"
    },
    {
      "name": "glad"
    },
    {
      "name": "glm"
    },
    {
      "name": "tinygltf"
    },
    {
      "name": "stb"
    },
    {
      "name": "entt"
    },
    {
      "name": "nlohmann-json"
    },
    {
      "name": "imgui",
      "features": ["docking-experimental", "glfw-binding", "opengl3-binding"]
    }
  ]
}
